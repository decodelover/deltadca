NODE_ENV=production
PORT=5000
FRONTEND_URL=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com,https://www.app.example.com
JWT_SECRET=replace-with-a-long-random-secret
MARKET_DATA_PROVIDER=coinmarketcap
MARKET_HISTORY_WINDOW_DAYS=730
COINMARKETCAP_API_KEY=replace-with-your-coinmarketcap-api-key
COINMARKETCAP_API_BASE_URL=https://pro-api.coinmarketcap.com

# Use either DATABASE_URL or the discrete DB_* variables below.
DATABASE_URL=postgresql://username:password@hostname:5432/deltadca_db
DB_SSL=true

# Optional fallback if you are not using DATABASE_URL.
DB_USER=postgres
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deltadca_db

# Optional tuning.
TRUST_PROXY=true
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=12
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
